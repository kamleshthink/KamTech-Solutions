# RewriteCond %{HTTP_REFERER} !^$
# RewriteCond %{HTTP_REFERER} !^https?://(www\.)?kamtech-solutions\.onrender\.com [NC]
# RewriteRule \.(gif|jpg|jpeg|png|svg)$ - [F,NC,L]